SECRET_KEY=dev-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DATABASE_URL=postgresql://balanco:balanco@postgres:5432/balanco
REDIS_URL=redis://redis:6379/0
MEDIA_ROOT=/app/media
MEDIA_URL=/media/
STATIC_URL=/static/
CELERY_TASK_ALWAYS_EAGER=false
STORAGE_BACKEND=local
LOG_LEVEL=INFO
OPENAI_API_KEY=
OPENAI_BALANCE_EXTRACTION_ENABLED=false
OPENAI_BALANCE_EXTRACTION_MODEL=gpt-5.4-mini
# Tarifas em USD por 1 milhão de tokens; preencha conforme o modelo contratado.
OPENAI_INPUT_USD_PER_MILLION_TOKENS=0.75
OPENAI_CACHED_INPUT_USD_PER_MILLION_TOKENS=0.075
OPENAI_OUTPUT_USD_PER_MILLION_TOKENS=4.5
# Cotação usada apenas para a estimativa exibida na aplicação.
USD_BRL_EXCHANGE_RATE=5.2
# Tolerâncias para validação contábil determinística.
ACCOUNTING_VALIDATION_AMOUNT_TOLERANCE=0.01
ACCOUNTING_VALIDATION_RATIO_TOLERANCE=0.01
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

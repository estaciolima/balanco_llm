SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

DATABASE_URL=postgresql://balanco:balanco@postgres:5432/balanco
REDIS_URL=redis://redis:6379/0
MEDIA_ROOT=/app/media
MEDIA_URL=/media/
STATIC_URL=/static/
CELERY_TASK_ALWAYS_EAGER=false
STORAGE_BACKEND=local
LOG_LEVEL=INFO

OPENAI_API_KEY=
OPENAI_BALANCE_EXTRACTION_ENABLED=true
OPENAI_BALANCE_EXTRACTION_MODEL=gpt-5.4-mini
OPENAI_INPUT_USD_PER_MILLION_TOKENS=0.75
OPENAI_CACHED_INPUT_USD_PER_MILLION_TOKENS=0.075
OPENAI_OUTPUT_USD_PER_MILLION_TOKENS=4.5
USD_BRL_EXCHANGE_RATE=5.2

ACCOUNTING_VALIDATION_AMOUNT_TOLERANCE=0.01
ACCOUNTING_VALIDATION_RATIO_TOLERANCE=0.01

# Use true when testing behind HTTPS. Keep false for local HTTP staging tests.
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
